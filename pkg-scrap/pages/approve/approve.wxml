<!-- pkg-scrap/pages/approve/approve.wxml —— M8.1.3 报废审批 -->
<view class="approve">
  <view wx:if="{{loading}}" class="muted card">加载中…</view>
  <view wx:for="{{list}}" wx:key="_id" class="card">
    <view class="row" style="justify-content: space-between;">
      <text class="name">{{item.name}}</text>
      <text class="muted">{{item.code}}</text>
    </view>
    <text class="muted">申请人：{{item.applicant}} · 原因：{{item.reason || '未填写'}}</text>
    <view class="acts">
      <button size="mini" type="primary" data-id="{{item._id}}" bindtap="onPass">通过</button>
      <button size="mini" bindtap="onReject" data-id="{{item._id}}">驳回</button>
    </view>
  </view>
  <view wx:if="{{!loading && list.length === 0}}" class="muted card">暂无待审批报废</view>
</view>
