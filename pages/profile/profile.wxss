/* pages/profile/profile.wxss —— 我的 */
.hero {
  margin: var(--sp-3);
  padding: var(--sp-5) var(--sp-4);
  border-radius: var(--r-lg);
  background: var(--c-hero-grad); color: #fff;
  display: flex; align-items: center; box-shadow: var(--sh-float);
  position: relative; overflow: hidden;
}
.hero::after {
  content: ''; position: absolute; right: -70rpx; bottom: -70rpx;
  width: 240rpx; height: 240rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}
.avatar {
  width: 112rpx; height: 112rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; font-weight: 700; margin-right: var(--sp-3); flex-shrink: 0;
  position: relative; z-index: 1;
}
.info { flex: 1; min-width: 0; position: relative; z-index: 1; }
.name { display: block; font-size: 38rpx; font-weight: 700; }
.sub-row { display: flex; align-items: center; flex-wrap: wrap; margin-top: 12rpx; gap: 12rpx; }
.role-pill { font-size: 22rpx; background: rgba(255, 255, 255, 0.2); padding: 4rpx 16rpx; border-radius: var(--r-pill); }
.org { font-size: 22rpx; opacity: 0.9; }
.ver { text-align: center; font-size: 22rpx; color: var(--c-text-weak); margin: var(--sp-4) 0; }
