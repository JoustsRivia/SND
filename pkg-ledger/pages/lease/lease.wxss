/* pkg-ledger/pages/lease/lease.wxss */
.lease { padding-bottom: 40rpx; }
.head { display: flex; justify-content: space-between; align-items: center; padding: 32rpx var(--sp-3); }
.title { font-size: 34rpx; font-weight: 600; }
.add .row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.add .label { width: 180rpx; font-size: 28rpx; }
.add .picker, .add .input { flex: 1; text-align: right; }
.add button { margin-top: 32rpx; background: var(--c-primary); }
.card { display: flex; flex-direction: column; }
.card .muted { margin-top: 8rpx; font-size: 24rpx; }
.tag { font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 8rpx; }
.tag-lease { background: var(--c-info-bg); color: var(--c-primary); }
