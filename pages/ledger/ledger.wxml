<!-- pages/ledger/ledger.wxml —— 台账列表（统计 + 筛查 + 卡片列表） -->
<view class="topbar">
  <view class="search">
    <text class="s-ico">🔍</text>
    <input class="s-input" placeholder="搜索器具名称 / 编号" value="{{keyword}}" bindinput="onSearch" confirm-type="search" />
    <text wx:if="{{keyword}}" class="s-clear" bindtap="clearSearch">✕</text>
  </view>
  <view class="actions">
    <view class="act" bindtap="onAdd">
      <text class="act-ico">➕</text><text>录入</text>
    </view>
    <view class="act" bindtap="onImport">
      <text class="act-ico">📥</text><text>导入</text>
    </view>
    <view class="act {{highRisk ? 'act-on' : ''}}" bindtap="onToggleHighRisk">
      <text class="act-ico">⚠️</text><text>高危专项</text>
    </view>
    <view class="act act-export" bindtap="onExport" wx:if="{{!exporting}}">
      <text class="act-ico">⬇️</text><text>导出台账</text>
    </view>
    <view class="act act-export" wx:else><text>导出中…</text></view>
  </view>
</view>

<!-- 问题6：按单位/机构分台账浏览 -->
<view class="subledger" wx:if="{{orgOptions.length > 1}}">
  <text class="sl-label">分台账</text>
  <picker mode="selector" range="{{orgOptions}}" range-key="label" value="{{orgIndex}}" bindchange="onOrgChange">
    <view class="sl-picker">{{orgOptions[orgIndex].label}} ▾</view>
  </picker>
</view>

<filter-bar tabs="{{tabs}}" activeTab="{{activeTab}}" chips="{{chips}}" activeChips="{{activeChips}}" bind:tab="onTab" bind:chip="onChip" />

<stats-card wx:if="{{stats.length}}" items="{{stats}}" columns="3" title="台账概况" />

<view wx:if="{{list.length}}" class="list">
  <tool-card wx:for="{{list}}" wx:key="_id" tool="{{item}}" bind:tap="onTapItem" />
  <view wx:if="{{loadingMore}}" class="loadmore">加载更多…</view>
  <view wx:elif="{{!hasMore}}" class="loadend">— 已加载全部 —</view>
</view>

<view wx:if="{{loading && !list.length}}" class="loading">加载中…</view>

<view wx:if="{{!loading && !list.length}}" class="empty">
  <view class="empty-icon">🗃️</view>
  <view class="empty-title">暂无匹配器具</view>
  <view class="empty-desc">试试切换状态、类别或分台账筛选</view>
  <view class="empty-act" bindtap="onAdd">＋ 手动录入一台器具</view>
</view>
<view class="safe-bottom"></view>
