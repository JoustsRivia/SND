/* pkg-check/pages/hazard/hazard.wxss */
.hazard { padding-bottom: 40rpx; }
.sec-title { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 16rpx; }
.row { display: flex; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.row.col { flex-direction: column; align-items: flex-start; }
.label { font-size: 28rpx; margin-bottom: 8rpx; }
.area { width: 100%; margin-top: 12rpx; height: 140rpx; font-size: 28rpx; }
.inp { width: 100%; font-size: 28rpx; border-bottom: 1rpx solid var(--c-divider); padding: 12rpx 0; }
.picker { flex: 1; text-align: right; color: var(--c-primary); }
.form button { margin-top: 24rpx; background: var(--c-primary); }
.hz { padding: 18rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.h-desc { font-size: 28rpx; font-weight: 500; }
.meta { margin-top: 8rpx; font-size: 26rpx; }
.center { text-align: center; padding: 20rpx 0; }

/* 子功能入口 */
.subnav { padding: 20rpx 24rpx; }
.subnav-title { font-size: 24rpx; color: #8A9099; }
.subnav-row { display: flex; gap: 16rpx; margin-top: 12rpx; }
.subnav-item {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 12rpx;
  background: #EEF3FF; color: #1A56DB; font-size: 28rpx; font-weight: 500;
}
