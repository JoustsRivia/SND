/* pkg-site/pages/briefing/briefing.wxss —— M6.2.3 班前交底 */
.form { padding: var(--sp-3); }
.card { background: var(--c-card); border-radius: var(--r-md); padding: var(--sp-3); box-shadow: var(--sh-card); }
.row { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.row.col { flex-direction: column; align-items: flex-start; }
.label { width: 170rpx; font-size: 28rpx; color: var(--c-text-sub); }
.input { flex: 1; text-align: right; font-size: 28rpx; }
.area { width: 100%; margin-top: 12rpx; height: 200rpx; font-size: 28rpx; }
.form button { margin-top: var(--sp-4); background: var(--c-primary-grad); color: #fff; border-radius: var(--r-pill); }
