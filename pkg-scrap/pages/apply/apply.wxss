/* pkg-scrap/pages/apply/apply.wxss */
.apply { padding-bottom: 40rpx; }
.row { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.row.col { flex-direction: column; align-items: flex-start; }
.label { width: 160rpx; font-size: 28rpx; }
.picker { flex: 1; text-align: right; }
.area { width: 100%; margin-top: 12rpx; height: 140rpx; font-size: 28rpx; }
.photos { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 12rpx; }
.ph { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: var(--c-tint-primary); color: var(--c-primary); display: flex; align-items: center; justify-content: center; font-size: 44rpx; }
.ph.add { border: 2rpx dashed var(--c-primary); }
.apply button { margin-top: 40rpx; background: var(--c-primary); }

/* M8.1.1 强制报废判定 */
.judge-box { align-items: stretch !important; }
.judge-head { display: flex; align-items: center; justify-content: space-between; width: 100%; }
.tag { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 999rpx; font-weight: 600; }
.tag-danger { background: #FEF2F2; color: #DC2626; }
.tag-ok { background: #E6F7EE; color: #059669; }
.rules { display: flex; flex-wrap: wrap; gap: 14rpx; margin-top: 16rpx; }
.rule {
  display: flex; align-items: center; gap: 8rpx;
  padding: 12rpx 18rpx; border-radius: 12rpx;
  background: #F3F4F6; color: #6B7280; font-size: 26rpx;
  border: 2rpx solid transparent;
}
.rule-on { background: #FEF2F2; color: #DC2626; border-color: #DC2626; font-weight: 600; }
.dot {
  width: 28rpx; height: 28rpx; border-radius: 50%;
  border: 2rpx solid var(--c-border); display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; color: #fff;
}
.rule-on .dot { background: #DC2626; border-color: #DC2626; }
.reasons { margin-top: 14rpx; font-size: 24rpx; color: #DC2626; background: #FEF2F2; padding: 12rpx 16rpx; border-radius: 12rpx; }

/* 子功能入口 */
.subnav { padding: 20rpx 24rpx; }
.subnav-title { font-size: 24rpx; color: #8A9099; }
.subnav-row { display: flex; gap: 16rpx; margin-top: 12rpx; }
.subnav-item {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 12rpx;
  background: #EEF3FF; color: #1A56DB; font-size: 28rpx; font-weight: 500;
}
