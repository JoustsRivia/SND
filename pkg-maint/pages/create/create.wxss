/* pkg-maint/pages/create/create.wxss */
.create { padding-bottom: 40rpx; }
.row { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.row.col { flex-direction: column; align-items: flex-start; }
.label { font-size: 28rpx; margin-bottom: 8rpx; }
.radio { display: flex; gap: 40rpx; margin-top: 8rpx; }
.opt { font-size: 28rpx; }
.inp { width: 100%; margin-top: 12rpx; font-size: 28rpx; }
.picker { text-align: right; font-size: 28rpx; color: var(--c-primary); }
.area { width: 100%; margin-top: 12rpx; height: 140rpx; font-size: 28rpx; }
.create button { margin-top: 40rpx; background: var(--c-primary); }
