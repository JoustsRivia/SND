<!-- pages/index/index.wxml —— 工作台（角色化九宫格 + 待办） -->
<view class="hero fade-in">
  <view class="hero-top">
    <view class="hero-user">
      <view class="avatar">{{avatarText}}</view>
      <view class="hero-meta">
        <text class="hello">{{greeting}}，{{profile.nickName || profile.username || '同事'}}</text>
        <view class="role-pill">{{roleText || '成员'}} · {{todayText}}</view>
      </view>
    </view>
    <view class="hero-badge">工作台</view>
  </view>

  <view class="hero-stat" wx:if="{{dashboard}}">
    <view class="hs-block">
      <text class="hs-num">{{dashboard.growth.qualifiedRate || 0}}%</text>
      <text class="hs-lbl">总体合格率</text>
    </view>
    <view class="hs-divider"></view>
    <view class="hs-block">
      <text class="hs-num warn">{{dashboard.growth.attention || 0}}</text>
      <text class="hs-lbl">待关注事项</text>
    </view>
  </view>
</view>

<stats-card items="{{stats}}" columns="4" />

<!-- 模块九宫格（按角色权限 + 分类动态展示） -->
<view class="section-head">
  <view class="section-title">功能模块</view>
  <view class="section-sub">{{roleText || '成员'}}可见</view>
</view>

<view wx:for="{{groups}}" wx:key="key" class="mod-group">
  <view class="mod-group-title">{{item.name}}</view>
  <view class="module-grid">
    <view wx:for="{{item.items}}" wx:for-item="m" wx:key="key" class="module-cell" hover-class="cell-hover"
          data-url="{{m.url}}" data-tab="{{m.tab ? 1 : 0}}" bindtap="onModule">
      <view class="module-icon">
        {{m.icon}}
        <view wx:if="{{m.badge}}" class="badge badge--{{m.badge.tone}}">{{m.badge.count > 99 ? '99+' : m.badge.count}}</view>
      </view>
      <view class="module-label">{{m.label}}</view>
    </view>
  </view>
</view>

<view class="section-head" wx:if="{{todos.length}}">
  <view class="section-title">待办事项</view>
</view>
<view class="card todo" wx:if="{{todos.length}}">
  <view wx:for="{{todos}}" wx:key="key" class="todo-row">
    <view class="todo-dot {{item.level}}"></view>
    <view class="todo-body">
      <text class="todo-title">{{item.title}}</text>
      <text class="todo-desc">{{item.desc}}</text>
    </view>
    <text class="todo-arrow">›</text>
  </view>
</view>

<view wx:if="{{!loading && !todos.length && dashboard}}" class="empty">
  <view class="empty-icon">🎉</view>
  <view class="empty-title">暂无待办</view>
  <view class="empty-desc">当前没有需要您处理的事项，保持关注即可</view>
</view>

<view wx:if="{{loading}}" class="loading">数据加载中…</view>

<view class="safe-bottom"></view>
