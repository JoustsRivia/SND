<!-- pkg-ledger/pages/lease/lease.wxml —— M1.3.7 租赁机具 -->
<view class="lease">
  <view class="head">
    <text class="title">租赁机具专项</text>
    <button size="mini" type="primary" bindtap="toggleAdd">{{showAdd ? '取消' : '新增'}}</button>
  </view>

  <view wx:if="{{showAdd}}" class="card add">
    <view class="row"><text class="label">类别</text>
      <picker mode="selector" range="{{categories}}" range-key="name" value="{{catIndex}}" bindchange="onCat">
        <view class="picker">{{categories[catIndex].name}} ▾</view></picker></view>
    <view class="row"><text class="label">机具名称</text><input class="input" placeholder="如：汽车吊（50t）" value="{{form.name}}" data-k="name" bindinput="bind" /></view>
    <view class="row"><text class="label">租赁单位</text><input class="input" placeholder="租赁公司" value="{{form.leaseUnit}}" data-k="leaseUnit" bindinput="bind" /></view>
    <view class="row"><text class="label">检测合格证</text><input class="input" placeholder="合格证编号" value="{{form.certNo}}" data-k="certNo" bindinput="bind" /></view>
    <view class="row"><text class="label">操作人员</text><input class="input" placeholder="姓名" value="{{form.operator}}" data-k="operator" bindinput="bind" /></view>
    <view class="row"><text class="label">操作证号</text><input class="input" placeholder="持证编号" value="{{form.operatorCert}}" data-k="operatorCert" bindinput="bind" /></view>
    <button type="primary" bindtap="onAdd">登记入库</button>
  </view>

  <view wx:if="{{loading}}" class="muted card">加载中…</view>
  <view wx:for="{{list}}" wx:key="_id" class="card">
    <view class="row" style="justify-content: space-between;">
      <text>{{item.name}}</text><text class="tag tag-lease">租赁</text>
    </view>
    <text class="muted">编号：{{item.code}} · {{item.store}}</text>
    <text class="muted">检测合格证：{{item.certNo || '未登记'}}</text>
  </view>
  <view wx:if="{{!loading && list.length === 0}}" class="muted card">暂无租赁机具</view>
</view>
