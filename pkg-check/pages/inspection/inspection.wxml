<!-- pkg-check/pages/inspection/inspection.wxml —— M10.1 监督检查任务 -->
<view class="inspection">
  <view wx:if="{{loading}}" class="muted center">加载中…</view>
  <block wx:else>
    <view wx:if="{{list.length === 0}}" class="muted center">暂无监督任务</view>
    <view wx:for="{{list}}" wx:key="_id" class="card task" data-item="{{item}}" bindtap="onPickTask">
      <view class="row" style="justify-content: space-between;">
        <text class="t-title">{{item.title}}</text>
        <status-tag status="{{item.status}}" size="sm" />
      </view>
      <view class="meta">
        <text class="muted">位置：{{item.location}}</text>
        <text class="muted">截止：{{item.dueDate}}</text>
      </view>
    </view>
  </block>

  <view wx:if="{{active}}" class="card form">
    <view class="row" style="justify-content: space-between;">
      <text class="f-title">{{active.title}}</text>
      <text class="cancel" bindtap="onCancel">取消✕</text>
    </view>
    <view class="row col">
      <text class="label">检查结果</text>
      <input class="inp" placeholder="如：合格 / 限期整改" value="{{result}}" bindinput="bindResult" />
    </view>
    <view class="row col">
      <text class="label">备注</text>
      <textarea class="area" placeholder="现场情况说明…" value="{{remark}}" bindinput="bindRemark" />
    </view>
    <button type="primary" bindtap="onSubmit">提交监督结果</button>
  </view>
</view>
