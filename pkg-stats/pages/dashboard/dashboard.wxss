/* pkg-stats/pages/dashboard/dashboard.wxss */
.dashboard { padding-bottom: 40rpx; }
.trend-row { display: flex; align-items: center; padding: 12rpx 0; }
.trend-date { width: 96rpx; font-size: 22rpx; color: var(--c-text-weak); flex-shrink: 0; }
.trend-bar-wrap { flex: 1; height: 20rpx; background: var(--c-divider); border-radius: var(--r-pill); margin: 0 16rpx; overflow: hidden; }
.trend-bar { height: 100%; background: var(--c-primary); border-radius: var(--r-pill); min-width: 4rpx; }
.trend-val { width: 70rpx; text-align: right; font-size: 22rpx; color: var(--c-text); flex-shrink: 0; }
.muted { color: var(--c-text-weak); font-size: 24rpx; padding: 12rpx 0; }
