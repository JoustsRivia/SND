<!-- pkg-borrow/pages/records/records.wxml —— M5 领用归还记录 -->
<view class="rec">
  <view class="tabs">
    <view wx:for="{{tabs}}" wx:key="v" class="tab {{type === item.v ? 'on' : ''}}" data-v="{{item.v}}" bindtap="onTab">{{item.n}}</view>
  </view>

  <view wx:if="{{loading}}" class="muted card">加载中…</view>
  <view wx:for="{{list}}" wx:key="_id" class="card">
    <view class="row" style="justify-content: space-between;">
      <text>{{item.name}}</text>
      <text class="tag {{item.type === 'borrow' ? 'tag-b' : 'tag-r'}}">{{item.type === 'borrow' ? '领用' : '归还'}}</text>
    </view>
    <text class="muted">编号：{{item.code}} · 领用人：{{item.by}}</text>
    <text class="muted">{{item.ts}} <text wx:if="{{item.appearance}}">· 外观：{{item.appearance}}</text></text>
  </view>
  <view wx:if="{{!loading && list.length === 0}}" class="muted card">暂无记录</view>
</view>
