<!-- pkg-site/pages/briefing/briefing.wxml —— M6.2.3 班前交底 -->
<view class="form">
  <view class="card">
    <view class="row"><text class="label">班组/作业面</text>
      <input class="input" placeholder="如：二班·35kV线路" value="{{team}}" data-k="team" bindinput="bind" /></view>
    <view class="row"><text class="label">交底日期</text>
      <input class="input" type="date" value="{{date}}" data-k="date" bindinput="bind" /></view>
    <view class="row col"><text class="label">参与人员</text>
      <input class="input" placeholder="如：张工、李工、王工" value="{{participants}}" data-k="participants" bindinput="bind" /></view>
    <view class="row col"><text class="label">交底内容</text>
      <textarea class="area" placeholder="风险点、管控措施、分工与应急…" value="{{content}}" data-k="content" bindinput="bind" /></view>
  </view>
  <button type="primary" loading="{{submitting}}" bindtap="onSubmit">提交班前交底</button>
</view>
