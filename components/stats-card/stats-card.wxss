/* components/stats-card/stats-card.wxss */
.scard { background: var(--c-card); border-radius: var(--r-md); padding: 24rpx; margin: var(--sp-3); box-shadow: var(--sh-card); }
.title { font-size: 28rpx; font-weight: 600; }
.grid { display: flex; flex-wrap: wrap; margin-top: 16rpx; }
.cell { display: flex; flex-direction: column; align-items: center; padding: 8rpx 0; box-sizing: border-box; }
.num { font-size: 38rpx; font-weight: 700; }
.lbl { font-size: 22rpx; color: var(--c-text-weak); margin-top: 6rpx; text-align: center; }
