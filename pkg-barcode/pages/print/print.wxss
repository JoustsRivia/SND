/* pkg-barcode/pages/print/print.wxss */
.print { padding-bottom: 40rpx; }
.row { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.label { width: 160rpx; font-size: 28rpx; }
.picker { flex: 1; text-align: right; }
.print .card button { margin: 16rpx 0 0 16rpx; background: var(--c-primary); }
.label-prev { display: flex; flex-direction: column; }
.label-prev .title { font-size: 30rpx; font-weight: 600; margin-bottom: 12rpx; }
.label-prev text { display: block; margin-top: 8rpx; font-size: 26rpx; }
