/* pkg-purchase/pages/accept/accept.wxss */
.step { padding: 24rpx; margin-bottom: 20rpx; }
.step-head { display: flex; align-items: center; justify-content: space-between; }
.step-label { font-size: 30rpx; font-weight: 600; color: var(--c-text); }
.step-desc { font-size: 22rpx; color: var(--c-text-weak); margin: 10rpx 0 16rpx; }
.seg { display: flex; border: 1rpx solid var(--c-divider); border-radius: var(--r-md); overflow: hidden; }
.seg-item { padding: 10rpx 24rpx; font-size: 24rpx; color: var(--c-text-weak); }
.seg-item.on { background: var(--c-primary); color: #fff; }
.seg-item.on.danger { background: var(--c-danger); }
.form-input.left { text-align: left; font-size: 26rpx; margin-top: 6rpx; }
