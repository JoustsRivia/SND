/* pkg-scrap/pages/disposal/disposal.wxss */
.disposal { padding-bottom: 40rpx; }
.card { display: flex; flex-direction: column; }
.card .name { font-size: 30rpx; font-weight: 600; }
.card .muted { margin-top: 8rpx; font-size: 24rpx; }
.row { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.row.col { flex-direction: column; align-items: flex-start; }
.label { width: 160rpx; font-size: 28rpx; }
.picker, .input { flex: 1; text-align: right; font-size: 28rpx; }
.photos { display: flex; gap: 16rpx; margin-top: 12rpx; }
.ph { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: var(--c-tint-primary); color: var(--c-primary); display: flex; align-items: center; justify-content: center; font-size: 44rpx; }
.ph.add { border: 2rpx dashed var(--c-primary); }
.disposal button { margin-top: 40rpx; background: var(--c-primary); }
