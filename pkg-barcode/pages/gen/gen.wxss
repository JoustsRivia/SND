/* pkg-barcode/pages/gen/gen.wxss —— M14.1 */
.gen { padding: 24rpx; }

/* 子功能入口 */
.subnav { padding: 20rpx 24rpx; }
.subnav-title { font-size: 24rpx; color: #8A9099; }
.subnav-row { display: flex; gap: 14rpx; margin-top: 12rpx; }
.subnav-item {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 12rpx;
  background: #EEF3FF; color: #1A56DB; font-size: 26rpx; font-weight: 500;
}
.card {
  background: var(--c-bg-card);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--c-shadow-card);
}
.row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.label { color: var(--c-text-weak); font-size: 26rpx; }
.picker {
  flex: 1; margin-left: 20rpx; padding: 16rpx 20rpx;
  background: var(--c-bg-soft); border-radius: 14rpx;
  font-size: 28rpx;
}
.btn-primary {
  margin-top: 8rpx;
  background: linear-gradient(135deg, var(--c-primary), var(--c-primary-deep));
  color: #fff; border-radius: 16rpx; font-size: 30rpx;
}
.btn-outline {
  margin-top: 20rpx; color: var(--c-primary);
  border: 2rpx solid var(--c-primary); background: transparent; border-radius: 16rpx;
}
.qr-card { display: flex; flex-direction: column; align-items: center; }
.qr-title { font-size: 28rpx; font-weight: 600; color: var(--c-text); margin-bottom: 16rpx; }
.qr-wrap {
  width: 440rpx; height: 440rpx; padding: 20rpx;
  background: #fff; border-radius: 20rpx; border: 2rpx solid var(--c-border);
  display: flex; align-items: center; justify-content: center;
}
.qr-canvas { width: 400rpx; height: 400rpx; }
.qr-meta { margin-top: 18rpx; display: flex; flex-direction: column; gap: 6rpx; font-size: 24rpx; color: var(--c-text-weak); text-align: center; }
.label-prev .title { font-size: 28rpx; font-weight: 600; color: var(--c-text); margin-bottom: 16rpx; }
.label-prev .kv { display: flex; justify-content: space-between; font-size: 26rpx; color: var(--c-text-weak); padding: 10rpx 0; border-bottom: 2rpx solid var(--c-border-weak); }
