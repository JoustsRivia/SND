/* =========================================================================
   app.wxss —— 全局设计系统（基于 ui-design.html 高保真设计稿抽取）
   设计语言：深蓝科技感 + 卡片化层次 + 柔和阴影 + 系统字体栈
   颜色 / 间距 / 圆角 / 阴影 / 字号 全部以 CSS 变量集中管理，页面按需引用，
   迁移或换肤只需改这里。
   ========================================================================= */

page {
  /* —— 品牌色 —— */
  --c-primary: #1A56DB;
  --c-primary-2: #2563EB;
  --c-primary-grad: linear-gradient(135deg, #1A56DB 0%, #2563EB 100%);
  --c-hero-grad: linear-gradient(160deg, #0F2B5B 0%, #1A56DB 55%, #2563EB 100%);
  --c-primary-soft: #E8F0FE;

  /* —— 语义色（状态 / 提示）—— */
  --c-success: #059669;  --c-success-bg: #E6F7EE;  --c-success-soft: #F0F9FF;
  --c-warning: #D97706;  --c-warning-bg: #FFF7ED;  --c-warning-soft: #FEF3C7;
  --c-danger: #DC2626;   --c-danger-bg: #FEF2F2;   --c-danger-soft: #FEE2E2;
  --c-info: #2563EB;     --c-info-bg: #E8F0FE;

  /* —— 图标底色（quick-actions / 选中 chip 的极浅语义底，区别于 -bg 的辉光底）—— */
  --c-tint-primary: #EAF3FB;
  --c-tint-success: #E7F8EC;
  --c-tint-warning: #FFF3E0;
  --c-tint-danger:  #FFE9E7;

  /* —— 文字层级 —— */
  --c-text: #1F2937;       /* 主文字 */
  --c-text-sub: #374151;   /* 次文字 */
  --c-text-muted: #6B7280; /* 弱化 */
  --c-text-weak: #9CA3AF;  /* 占位 / 极弱 */
  --c-text-faint: #8E8E93; /* 停用 / 中性标签灰 */
  --c-text-invert: #FFFFFF;

  /* —— 表面 / 描边 —— */
  --c-bg: #F5F7FA;
  --c-card: #FFFFFF;
  --c-surface: #F3F4F6;
  --c-surface-2: #F8FAFC;
  --c-border: #E5E7EB;
  --c-divider: #EEF1F5;
  --c-overlay: rgba(15, 43, 91, 0.45);

  /* —— 圆角 —— */
  --r-xs: 8rpx;
  --r-sm: 12rpx;
  --r-md: 16rpx;
  --r-lg: 24rpx;
  --r-xl: 32rpx;
  --r-pill: 999rpx;

  /* —— 间距尺度 —— */
  --sp-1: 8rpx;
  --sp-2: 16rpx;
  --sp-3: 24rpx;
  --sp-4: 32rpx;
  --sp-5: 48rpx;
  --sp-6: 64rpx;

  /* —— 阴影 —— */
  --sh-card: 0 4rpx 20rpx rgba(15, 43, 91, 0.06);
  --sh-card-hover: 0 8rpx 28rpx rgba(15, 43, 91, 0.10);
  --sh-up: 0 -4rpx 24rpx rgba(15, 43, 91, 0.06);
  --sh-float: 0 10rpx 30rpx rgba(26, 86, 219, 0.22);
  --sh-inset: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);

  /* —— 字号 —— */
  --fs-xs: 22rpx;
  --fs-sm: 24rpx;
  --fs-md: 28rpx;
  --fs-lg: 32rpx;
  --fs-xl: 40rpx;
  --fs-2xl: 48rpx;
  --fs-3xl: 64rpx;

  /* —— 兼容旧页面引用的别名（逐步迁移到 --c-* 即可，请勿删除以免旧页失色）—— */
  --color-primary: #1A56DB;
  --color-success: #059669;
  --color-warning: #D97706;
  --color-danger: #DC2626;
  --color-info: #2563EB;
  --color-text: #1F2937;
  --color-text-sub: #374151;
  --color-text-muted: #6B7280;
  --color-text-weak: #9CA3AF;
  --color-bg: #F5F7FA;
  --color-card: #FFFFFF;
  --color-surface: #F3F4F6;
  --color-border: #E5E7EB;
  --radius-card: 16rpx;
  --gap: 24rpx;

  /* —— 基础排版 —— */
  background: var(--c-bg);
  color: var(--c-text);
  font-size: var(--fs-md);
  line-height: 1.5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
}

view, text, scroll-view, button { box-sizing: border-box; }

/* ============================ 布局工具 ============================ */
.row { display: flex; align-items: center; }
.col { display: flex; flex-direction: column; }
.between { justify-content: space-between; }
.center { justify-content: center; align-items: center; }
.wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; min-width: 0; }
.gap-1 { gap: var(--sp-1); }
.gap-2 { gap: var(--sp-2); }
.gap-3 { gap: var(--sp-3); }

/* ============================ 容器 / 卡片 ============================ */
.page-pad { padding: var(--sp-3); }
.page-pad-x { padding-left: var(--sp-3); padding-right: var(--sp-3); }

.card {
  background: var(--c-card);
  border-radius: var(--r-md);
  padding: var(--sp-3);
  margin: var(--sp-3);
  box-shadow: var(--sh-card);
  position: relative;
}
.card-flat {
  background: var(--c-card);
  border-radius: var(--r-md);
  padding: var(--sp-3);
  margin: var(--sp-3);
  border: 1rpx solid var(--c-divider);
}
.card-lg { border-radius: var(--r-lg); padding: var(--sp-4); }
.card-sm { padding: var(--sp-2); border-radius: var(--r-sm); }

/* 区块标题 */
.section { margin: var(--sp-3) var(--sp-3) 0; }
.section-title {
  font-size: var(--fs-lg);
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: 0.5rpx;
}
.section-sub { font-size: var(--fs-sm); color: var(--c-text-muted); margin-top: 4rpx; }
.section-head {
  display: flex; align-items: center; justify-content: space-between;
  margin: var(--sp-4) var(--sp-3) var(--sp-1);
}
.section-head .more { font-size: var(--fs-sm); color: var(--c-primary); }

/* ============================ 文字工具 ============================ */
.muted { color: var(--c-text-muted); }
.weak { color: var(--c-text-weak); }
.sub { color: var(--c-text-sub); }
.invert { color: var(--c-text-invert); }
.bold { font-weight: 700; }
.t-xs { font-size: var(--fs-xs); }
.t-sm { font-size: var(--fs-sm); }
.t-lg { font-size: var(--fs-lg); }
.t-xl { font-size: var(--fs-xl); }
.t-2xl { font-size: var(--fs-2xl); }
.t-3xl { font-size: var(--fs-3xl); }
.t-num { font-variant-numeric: tabular-nums; font-weight: 700; }

/* 截断 */
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 {
  display: -webkit-box; -webkit-box-orient: vertical;
  -webkit-line-clamp: 2; overflow: hidden;
}

/* ============================ 胶囊 / 徽标 ============================ */
.pill {
  display: inline-flex; align-items: center; gap: 4rpx;
  padding: 4rpx 16rpx; border-radius: var(--r-pill);
  font-size: var(--fs-xs); font-weight: 600; line-height: 1.6;
}
.pill-primary { background: var(--c-primary-soft); color: var(--c-primary); }
.pill-success { background: var(--c-success-bg); color: var(--c-success); }
.pill-warning { background: var(--c-warning-bg); color: var(--c-warning); }
.pill-danger { background: var(--c-danger-bg); color: var(--c-danger); }
.pill-info { background: var(--c-info-bg); color: var(--c-info); }
.pill-ghost { background: var(--c-surface); color: var(--c-text-muted); }

.badge {
  min-width: 32rpx; height: 32rpx; padding: 0 8rpx;
  border-radius: var(--r-pill); background: var(--c-danger);
  color: #fff; font-size: 20rpx; line-height: 32rpx; text-align: center;
}
/* 徽标语义 tone（九宫格模块实时状态；色值取自状态令牌，禁止硬编码） */
.badge--pending { background: var(--c-pending); }
.badge--abnormal { background: var(--c-abnormal); }

/* ============================ 按钮 ============================ */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8rpx;
  height: 88rpx; padding: 0 var(--sp-4); border-radius: var(--r-pill);
  font-size: var(--fs-lg); font-weight: 600; border: none; line-height: 1;
}
.btn::after { border: none; }
.btn-primary { background: var(--c-primary-grad); color: #fff; box-shadow: var(--sh-float); }
.btn-ghost { background: var(--c-surface); color: var(--c-text-sub); }
.btn-outline { background: #fff; color: var(--c-primary); border: 1rpx solid var(--c-primary); }
.btn-block { width: 100%; }
.btn[disabled] { opacity: 0.5; }

/* ============================ 分隔 / 安全区 ============================ */
.divider { height: 1rpx; background: var(--c-divider); margin: var(--sp-2) 0; }
.safe-bottom { padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx); }
.safe-top { padding-top: calc(env(safe-area-inset-top) + 24rpx); }

/* ============================ 渐变 Hero ============================ */
.hero {
  background: var(--c-hero-grad);
  padding: calc(env(safe-area-inset-top) + 48rpx) var(--sp-4) var(--sp-5);
  color: #fff;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: ''; position: absolute; right: -80rpx; top: -80rpx;
  width: 320rpx; height: 320rpx; border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}
.hero-grad { background: var(--c-hero-grad); color: #fff; }
.grad-primary { background: var(--c-primary-grad); color: #fff; }

/* ============================ 空 / 错误态 ============================ */
.empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: var(--sp-6) var(--sp-4); color: var(--c-text-weak); text-align: center;
}
.empty .empty-icon { font-size: 96rpx; margin-bottom: var(--sp-2); opacity: 0.7; }
.empty .empty-title { font-size: var(--fs-lg); color: var(--c-text-muted); font-weight: 600; }
.empty .empty-desc { font-size: var(--fs-sm); margin-top: var(--sp-1); }

/* 加载 */
.loading {
  display: flex; align-items: center; justify-content: center;
  padding: var(--sp-5); color: var(--c-text-weak); font-size: var(--fs-sm);
}

/* 浮动操作按钮 */
.fab {
  position: fixed; right: var(--sp-4); bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  width: 104rpx; height: 104rpx; border-radius: 50%;
  background: var(--c-primary-grad); box-shadow: var(--sh-float);
  display: flex; align-items: center; justify-content: center; z-index: 50;
}

/* 通用进场动效 */
.fade-in { animation: fadeIn 0.4s ease both; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(12rpx); } to { opacity: 1; transform: none; } }

/* =========================================================================
   设计系统 v2 扩展（见 DESIGN_SYSTEM.md）：状态语义色 / 动效 / 流程时间线
   全部以令牌表达，页面只引用类名，禁止硬编码色值
   ========================================================================= */

/* —— 状态语义色（器具/任务状态，区别于品牌蓝）—— */
page {
  --c-qualified: #059669;  --c-qualified-bg: #E6F7EE;  --c-qualified-tint: #E7F8EC;
  --c-inuse: #2563EB;      --c-inuse-bg: #E8F0FE;      --c-inuse-tint: #EAF3FB;
  --c-pending: #D97706;    --c-pending-bg: #FFF7ED;    --c-pending-tint: #FFF3E0;
  --c-abnormal: #DC2626;   --c-abnormal-bg: #FEF2F2;   --c-abnormal-tint: #FFE9E7;
  --c-maint: #7C3AED;      --c-maint-bg: #F5F3FF;      --c-maint-tint: #EFEAFD;
  --c-scrapped: #6B7280;   --c-scrapped-bg: #F3F4F6;   --c-scrapped-tint: #ECEEF1;

  /* —— 扩展圆角 / 间距 / 阴影 —— */
  --r-2xl: 40rpx;
  --sp-7: 80rpx;
  --sh-rail: inset 3rpx 0 0 var(--c-inuse);

  /* —— 动效令牌（指数缓出，禁用回弹）—— */
  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  --dur-fast: 160ms;  --dur-base: 280ms;  --dur-slow: 420ms;

  /* —— 展示/数字字号 —— */
  --fs-hero: 72rpx;  --fs-display: 56rpx;

  /* —— 字体族（等宽数字；SNDNum 未就绪时回退系统等宽栈）—— */
  --font-num: 'SNDNum', 'SF Mono', 'Roboto Mono', ui-monospace, 'Courier New', monospace;
}

/* ============================ 状态轨卡片 ============================ */
.card--status { position: relative; overflow: hidden; }
.card--status::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 6rpx;
  background: var(--rail, var(--c-inuse));
}
.card--qualified { --rail: var(--c-qualified); }
.card--inuse { --rail: var(--c-inuse); }
.card--pending { --rail: var(--c-pending); }
.card--abnormal { --rail: var(--c-abnormal); }
.card--maint { --rail: var(--c-maint); }
.card--scrapped { --rail: var(--c-scrapped); }

/* ============================ 状态药丸 ============================ */
.pill-qualified { background: var(--c-qualified-bg); color: var(--c-qualified); }
.pill-inuse { background: var(--c-inuse-bg); color: var(--c-inuse); }
.pill-pending { background: var(--c-pending-bg); color: var(--c-pending); }
.pill-abnormal { background: var(--c-abnormal-bg); color: var(--c-abnormal); }
.pill-maint { background: var(--c-maint-bg); color: var(--c-maint); }
.pill-scrapped { background: var(--c-scrapped-bg); color: var(--c-scrapped); }

/* 红点 */
.dot {
  display: inline-block; width: 16rpx; height: 16rpx; border-radius: 50%;
  background: var(--c-abnormal); vertical-align: middle;
}

/* ============================ 流程时间线 ============================ */
.flow { padding-left: var(--sp-1); }
.flow-item { position: relative; padding: 0 0 var(--sp-3) var(--sp-5); }
.flow-item::before {
  content: ''; position: absolute; left: 14rpx; top: 36rpx; bottom: 0; width: 4rpx;
  background: linear-gradient(var(--c-qualified), var(--c-border));
}
.flow-item:last-child::before { display: none; }
.flow-node {
  position: absolute; left: 0; top: 6rpx; width: 32rpx; height: 32rpx; border-radius: 50%;
  border: 4rpx solid var(--c-border); background: var(--c-card);
  display: flex; align-items: center; justify-content: center;
}
.flow-node--done { border-color: var(--c-qualified); background: var(--c-qualified); }
.flow-node--active { border-color: var(--c-inuse); background: var(--c-inuse); box-shadow: 0 0 0 6rpx var(--c-inuse-tint); }
.flow-node--wait { border-color: var(--c-pending); }
.flow-title { font-size: var(--fs-md); font-weight: 600; color: var(--c-text); }
.flow-meta { font-size: var(--fs-xs); color: var(--c-text-muted); margin-top: 4rpx; }
.flow-item--done .flow-title { color: var(--c-text-sub); }

/* ============================ 展示/数字 ============================ */
.t-display { font-size: var(--fs-display); font-weight: 700; line-height: 1.1; }
.t-hero { font-size: var(--fs-hero); font-weight: 800; line-height: 1; }

/* ============================ 字体（见 utils/fonts.js 加载脚手架） ============================ */
/* 等宽数字：仪表盘统计、Hero 数字等；SNDNum 未就绪时自动回退系统等宽栈，
   故离线/被网络策略拦截也不影响排版，仅数字字距略变。 */
.font-num {
  font-family: var(--font-num);
  font-variant-numeric: tabular-nums;
  font-feature-settings: 'tnum' 1;
}
/* 展示标题字：与等宽数字同源，保证大字号下的数字一致性 */
.font-display {
  font-family: var(--font-num), -apple-system, 'PingFang SC', sans-serif;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}
/* 图标字体（可选）：SNDIcon 就绪后生效；未加载时回退系统字体（emoji 仍正常显示）。
   接入步骤见 utils/fonts.js 顶部注释与 DESIGN_SYSTEM.md §6 / P2。 */
.iconfont {
  font-family: 'SNDIcon', -apple-system, sans-serif;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
}

/* 进场错峰 */
.fade-in-1 { animation: fadeIn var(--dur-base) var(--ease-out) both; }
.fade-in-2 { animation: fadeIn var(--dur-base) var(--ease-out) 80ms both; }
.fade-in-3 { animation: fadeIn var(--dur-base) var(--ease-out) 160ms both; }

/* =========================================================================
   夜间主题（深色作业终端风）
   - 自动：跟随系统 prefers-color-scheme: dark，覆盖所有页面
   - 手动：.theme-dark 类（由 profile 切换持久化），覆盖 opted-in 页面根视图
   两套声明内容一致，仅作用域不同（page / .theme-dark 容器）。
   ========================================================================= */
@media (prefers-color-scheme: dark) {
  page {
    --c-bg: #0F172A;  --c-card: #1E293B;  --c-surface: #172033;  --c-surface-2: #1E293B;
    --c-border: #334155;  --c-divider: #2A3A52;  --c-overlay: rgba(0, 0, 0, 0.55);
    --c-text: #E5E7EB;  --c-text-sub: #CBD5E1;  --c-text-muted: #94A3B8;
    --c-text-weak: #64748B;  --c-text-faint: #475569;
    --c-primary: #3B82F6;  --c-primary-2: #60A5FA;
    --c-primary-grad: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 100%);
    --c-hero-grad: linear-gradient(160deg, #0B1220 0%, #1E3A8A 55%, #2563EB 100%);
    --c-primary-soft: #16233B;
    --c-success: #34D399;  --c-success-bg: #0E2A20;  --c-success-soft: #103025;
    --c-warning: #FBBF24;  --c-warning-bg: #2E2410;  --c-warning-soft: #2E2410;
    --c-danger: #F87171;   --c-danger-bg: #2A1414;   --c-danger-soft: #2E1717;
    --c-info: #60A5FA;     --c-info-bg: #10243F;
    --c-tint-primary: #13294A;  --c-tint-success: #103025;  --c-tint-warning: #2E2410;  --c-tint-danger: #2E1717;
    --c-qualified: #34D399;  --c-qualified-bg: #0E2A20;  --c-qualified-tint: #103025;
    --c-inuse: #60A5FA;      --c-inuse-bg: #10243F;      --c-inuse-tint: #13294A;
    --c-pending: #FBBF24;    --c-pending-bg: #2E2410;    --c-pending-tint: #2E2410;
    --c-abnormal: #F87171;   --c-abnormal-bg: #2A1414;   --c-abnormal-tint: #2E1717;
    --c-maint: #A78BFA;      --c-maint-bg: #1E1B33;      --c-maint-tint: #211D38;
    --c-scrapped: #94A3B8;   --c-scrapped-bg: #1E293B;   --c-scrapped-tint: #22304A;
    --sh-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.45);
    --sh-card-hover: 0 8rpx 28rpx rgba(0, 0, 0, 0.55);
    --sh-float: 0 10rpx 30rpx rgba(59, 130, 246, 0.30);
  }
}
.theme-dark {
  --c-bg: #0F172A;  --c-card: #1E293B;  --c-surface: #172033;  --c-surface-2: #1E293B;
  --c-border: #334155;  --c-divider: #2A3A52;  --c-overlay: rgba(0, 0, 0, 0.55);
  --c-text: #E5E7EB;  --c-text-sub: #CBD5E1;  --c-text-muted: #94A3B8;
  --c-text-weak: #64748B;  --c-text-faint: #475569;
  --c-primary: #3B82F6;  --c-primary-2: #60A5FA;
  --c-primary-grad: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 100%);
  --c-hero-grad: linear-gradient(160deg, #0B1220 0%, #1E3A8A 55%, #2563EB 100%);
  --c-primary-soft: #16233B;
  --c-success: #34D399;  --c-success-bg: #0E2A20;  --c-success-soft: #103025;
  --c-warning: #FBBF24;  --c-warning-bg: #2E2410;  --c-warning-soft: #2E2410;
  --c-danger: #F87171;   --c-danger-bg: #2A1414;   --c-danger-soft: #2E1717;
  --c-info: #60A5FA;     --c-info-bg: #10243F;
  --c-tint-primary: #13294A;  --c-tint-success: #103025;  --c-tint-warning: #2E2410;  --c-tint-danger: #2E1717;
  --c-qualified: #34D399;  --c-qualified-bg: #0E2A20;  --c-qualified-tint: #103025;
  --c-inuse: #60A5FA;      --c-inuse-bg: #10243F;      --c-inuse-tint: #13294A;
  --c-pending: #FBBF24;    --c-pending-bg: #2E2410;    --c-pending-tint: #2E2410;
  --c-abnormal: #F87171;   --c-abnormal-bg: #2A1414;   --c-abnormal-tint: #2E1717;
  --c-maint: #A78BFA;      --c-maint-bg: #1E1B33;      --c-maint-tint: #211D38;
  --c-scrapped: #94A3B8;   --c-scrapped-bg: #1E293B;   --c-scrapped-tint: #22304A;
  --sh-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.45);
  --sh-card-hover: 0 8rpx 28rpx rgba(0, 0, 0, 0.55);
  --sh-float: 0 10rpx 30rpx rgba(59, 130, 246, 0.30);
  min-height: 100vh;
}
