/* pages/ledger/ledger.wxss —— 台账 */
.topbar {
  position: sticky; top: 0; z-index: 10;
  padding: var(--sp-2) var(--sp-3);
  background: var(--c-bg);
}
.search {
  display: flex; align-items: center;
  background: var(--c-card); border-radius: var(--r-pill);
  padding: 0 var(--sp-3); height: 76rpx;
  box-shadow: var(--sh-card);
}
.s-ico { font-size: 28rpx; margin-right: 12rpx; opacity: 0.6; }
.s-input { flex: 1; font-size: 28rpx; height: 76rpx; }
.s-clear {
  font-size: 28rpx; color: var(--c-text-weak);
  width: 44rpx; height: 44rpx; line-height: 44rpx; text-align: center;
}
.actions { display: flex; gap: var(--sp-2); padding: var(--sp-2) 0 0; }
.act {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx;
  height: 72rpx; border-radius: var(--r-pill);
  background: var(--c-card); color: var(--c-text-sub);
  font-size: var(--fs-sm); font-weight: 600;
  box-shadow: var(--sh-card); border: 2rpx solid transparent;
  transition: all 0.2s;
}
.act-ico { font-size: 26rpx; }
.act-on { background: var(--c-warning-soft); color: var(--c-warning); border-color: var(--c-warning); }
.act-export { background: var(--c-primary-soft); color: var(--c-primary); }

/* 问题6：分台账筛选条 */
.subledger { display: flex; align-items: center; gap: var(--sp-2); padding: var(--sp-2) var(--sp-3) 0; }
.sl-label { font-size: 26rpx; color: var(--c-text-sub); }
.sl-picker {
  flex: 1; text-align: center; height: 64rpx; line-height: 64rpx;
  background: var(--c-card); border-radius: var(--r-pill); color: var(--c-text);
  font-size: 26rpx; box-shadow: var(--sh-card);
}

.list { padding: var(--sp-1) var(--sp-3) 0; }
.loadmore, .loadend { text-align: center; color: var(--c-text-weak); font-size: var(--fs-sm); padding: var(--sp-3) 0; }
.loading { text-align: center; }
.empty-act {
  margin-top: var(--sp-3); padding: 20rpx 0; text-align: center;
  background: var(--c-primary-soft); color: var(--c-primary);
  border-radius: var(--r-md); font-size: 28rpx; font-weight: 600;
}
