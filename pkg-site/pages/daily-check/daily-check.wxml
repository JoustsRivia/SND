<!-- pkg-site/pages/daily-check/daily-check.wxml —— M6 每日点检汇总看板 -->
<view wx:if="{{loading}}" class="loading">加载中…</view>
<block wx:else>
  <!-- 子功能：操作规程 / 班前交底 -->
  <view class="subnav">
    <view class="subnav-item" data-url="/pkg-site/pages/guide/guide" bindtap="onGo">操作规程</view>
    <view class="subnav-item" data-url="/pkg-site/pages/briefing/briefing" bindtap="onGo">班前交底</view>
  </view>

  <view class="hero">
    <view class="hero-top">
      <text class="date">{{date}}</text>
      <text class="badge">每日点检</text>
    </view>
    <view class="progress">
      <text class="p-num">{{done}}/{{total}}</text>
      <text class="p-lbl">已完成 · 达标 {{rate}}%</text>
    </view>
    <view class="bar"><view class="bar-in" style="width:{{rate}}%;"></view></view>
  </view>

  <view class="section-head"><text class="section-title">点检明细</text></view>
  <view class="card">
    <view wx:if="{{!items.length}}" class="empty">
      <view class="empty-icon">🗒️</view>
      <view class="empty-title">暂无以点检器具</view>
      <view class="empty-desc">点击下方按钮，开始今日班前点检</view>
    </view>
    <view wx:for="{{items}}" wx:key="toolId" class="row" data-item="{{item}}" bindtap="onTapItem">
      <view class="status {{item.status}}"></view>
      <view class="body">
        <text class="name">{{item.name}}</text>
        <text class="code">{{item.code}} · {{item.categoryText}}</text>
      </view>
      <text class="state-text {{item.status}}">{{item.status === 'normal' ? '正常' : item.status === 'abnormal' ? '异常' : '待检'}}</text>
      <text wx:if="{{item.status === 'pending'}}" class="go">›</text>
    </view>
  </view>

  <view class="btn grad-primary block" bindtap="goCheck">＋ 新增点检</view>
  <view class="safe-bottom"></view>
</block>
