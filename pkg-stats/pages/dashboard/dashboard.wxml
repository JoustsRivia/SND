<!-- pkg-stats/pages/dashboard/dashboard.wxml —— M12.1 统计分析看板 -->
<view class="dashboard page-pad {{themeClass}}">
  <view wx:if="{{loading}}" class="card muted">加载中…</view>
  <block wx:else>
    <view class="card">
      <stats-card items="{{items}}" columns="{{4}}" />
    </view>

    <chart type="pie" series="{{statusPie}}" title="器具状态分布" />
    <chart type="line" series="{{trendSeries}}" title="近 7 日器具总量趋势" height="{{220}}" />

    <view class="row gap-2">
      <button class="btn btn-outline flex-1" bindtap="goSix">六化达标</button>
      <button class="btn btn-outline flex-1" bindtap="goReport">报表导出</button>
    </view>
  </block>
  <view class="safe-bottom"></view>
</view>
