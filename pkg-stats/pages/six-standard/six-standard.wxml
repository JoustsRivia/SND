<!-- pkg-stats/pages/six-standard/six-standard.wxml —— M12.2 六化达标分析 -->
<view class="six">
  <view wx:if="{{loading}}" class="card muted">加载中…</view>
  <view wx:else class="card">
    <text class="title">六化达标</text>
    <view wx:for="{{dims}}" wx:key="key" class="dim">
      <view class="dim-head">
        <text class="name">{{item.name}}</text>
        <text class="muted">{{item.done}}/{{item.total}} ({{item.rate}}%)</text>
      </view>
      <view class="track">
        <view class="fill" style="width: {{item.rate}}%;"></view>
      </view>
    </view>
    <view wx:if="{{dims.length === 0}}" class="muted">暂无数据</view>
  </view>
</view>
