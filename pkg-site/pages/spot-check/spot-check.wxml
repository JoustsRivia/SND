<!-- pkg-site/pages/spot-check/spot-check.wxml —— M6 现场点检 -->
<view class="spot-check">
  <view class="hero">
    <text class="h-title">现场点检</text>
    <text class="h-sub">{{taskDate || '今日'}} · 逐项确认器具状态</text>
  </view>

  <view class="card">
    <view class="row">
      <text class="label">器具编号</text>
      <input class="inp" placeholder="选填，可录入被检器具编号" value="{{toolId}}" bindinput="bindToolId" />
    </view>
  </view>

  <view class="card">
    <text class="label blk">点检项（合格 / 异常）</text>
    <view wx:if="{{items.length === 0}}" class="empty">
      <view class="empty-icon">📝</view>
      <view class="empty-title">暂无点检任务</view>
    </view>
    <view wx:for="{{items}}" wx:key="text" class="check-row">
      <text class="ctext {{item.result === '合格' ? 'ok' : 'bad'}}">{{item.text}}</text>
      <switch checked="{{item.result === '合格'}}" color="#1A56DB" data-index="{{index}}" bindchange="onToggle" />
    </view>
  </view>

  <view class="card">
    <view class="row">
      <text class="label">是否异常</text>
      <switch checked="{{abnormal}}" color="#DC2626" bindchange="onAbnormal" />
    </view>
    <view class="row col">
      <text class="label blk">现场备注</text>
      <textarea class="area" placeholder="异常说明 / 现场备注" value="{{remark}}" bindinput="bindRemark" />
    </view>
  </view>

  <view class="btn grad-primary block {{submitting ? 'dis' : ''}}" bindtap="onSubmit">{{submitting ? '提交中…' : '提交点检'}}</view>
  <view class="safe-bottom"></view>
</view>
