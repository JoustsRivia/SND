/* pkg-site/pages/daily-check/daily-check.wxss —— 每日点检看板 */
.hero {
  margin: var(--sp-3); padding: var(--sp-4) var(--sp-4) var(--sp-5);
  border-radius: var(--r-lg); background: var(--c-hero-grad); color: #fff;
  box-shadow: var(--sh-float); position: relative; overflow: hidden;
}
.hero::after {
  content: ''; position: absolute; right: -80rpx; top: -80rpx;
  width: 260rpx; height: 260rpx; border-radius: 50%; background: rgba(255,255,255,0.07);
}
.hero-top { display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1; }
.date { font-size: 34rpx; font-weight: 700; }
.badge { font-size: 22rpx; background: rgba(255,255,255,0.2); padding: 6rpx 18rpx; border-radius: var(--r-pill); }
.progress { margin-top: var(--sp-4); display: flex; align-items: baseline; position: relative; z-index: 1; }
.p-num { font-size: 56rpx; font-weight: 800; font-variant-numeric: tabular-nums; }
.p-lbl { margin-left: 16rpx; font-size: 24rpx; opacity: 0.85; }
.bar { margin-top: 20rpx; height: 14rpx; background: rgba(255,255,255,0.25); border-radius: var(--r-pill); overflow: hidden; position: relative; z-index: 1; }
.bar-in { height: 100%; background: #fff; border-radius: var(--r-pill); transition: width 0.4s ease; }
.section-head { margin: var(--sp-4) var(--sp-3) var(--sp-1); }
.section-title { font-size: var(--fs-lg); font-weight: 700; }

.card { padding: var(--sp-3); margin: 0 var(--sp-3); background: var(--c-card); border-radius: var(--r-md); box-shadow: var(--sh-card); }
.row { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.row:last-child { border-bottom: none; }
.status { width: 18rpx; height: 18rpx; border-radius: 50%; margin-right: 20rpx; flex-shrink: 0; background: var(--c-text-weak); }
.status.normal { background: var(--c-success); box-shadow: 0 0 0 6rpx var(--c-success-bg); }
.status.abnormal { background: var(--c-danger); box-shadow: 0 0 0 6rpx var(--c-danger-bg); }
.status.pending { background: var(--c-warning); box-shadow: 0 0 0 6rpx var(--c-warning-bg); }
.body { flex: 1; min-width: 0; }
.name { display: block; font-size: 28rpx; font-weight: 500; }
.code { display: block; margin-top: 6rpx; font-size: 22rpx; color: var(--c-text-weak); }
.state-text { font-size: 24rpx; margin-left: 12rpx; flex-shrink: 0; }
.state-text.normal { color: var(--c-success); }
.state-text.abnormal { color: var(--c-danger); }
.state-text.pending { color: var(--c-warning); }
.go { font-size: 40rpx; color: var(--c-text-weak); margin-left: 8rpx; }
.btn.block { margin: var(--sp-4) var(--sp-3) 0; }
.loading { text-align: center; }
