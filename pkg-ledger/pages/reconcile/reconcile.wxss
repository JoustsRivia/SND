/* pkg-ledger/pages/reconcile/reconcile.wxss */
.rec { padding: 20rpx 24rpx 40rpx; }
.tabs { display: flex; background: #fff; border-radius: 14rpx; overflow: hidden; margin-bottom: 20rpx; }
.tab { flex: 1; text-align: center; padding: 22rpx 0; font-size: 28rpx; color: #6b7280; }
.tab.on { color: #1A56DB; font-weight: 600; background: #eef3ff; }
.add { background: #1A56DB; color: #fff; margin-bottom: 20rpx; }
.empty { text-align: center; color: #9AA0A6; padding: 100rpx 0; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 18rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.hd { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.month { font-weight: 600; font-size: 30rpx; }
.row { display: flex; gap: 16rpx; font-size: 26rpx; padding: 4rpx 0; }
.k { color: #8A9099; width: 120rpx; flex-shrink: 0; }
.v { color: #1f2329; flex: 1; }
.v.bad { color: #E5484D; font-weight: 600; }
.pill { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; }
.pill.ok { background: #E6F7EC; color: #1A9E5B; }
.pill.warn { background: #FFF4E5; color: #C77700; }
.pill.gray { background: #f1f3f5; color: #6b7280; }
.pill.info { background: #E6F0FF; color: #1A56DB; }
.pill.bad { background: #FDECEC; color: #E5484D; }

.mask { position: fixed; inset: 0; background: rgba(0,0,0,0.45); display: flex; align-items: flex-end; z-index: 50; }
.sheet { width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 28rpx; box-sizing: border-box; max-height: 84vh; display: flex; flex-direction: column; }
.sheet-hd { display: flex; justify-content: space-between; align-items: center; font-size: 32rpx; font-weight: 600; margin-bottom: 16rpx; }
.items { flex: 1; overflow: hidden; }
.item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f2f5; }
.item-hd { display: flex; gap: 12rpx; align-items: baseline; }
.code { color: #6b7280; font-size: 24rpx; }
.name { font-size: 28rpx; font-weight: 500; }
.item-sub { font-size: 24rpx; color: #8A9099; margin: 4rpx 0 10rpx; }
.seg { display: flex; gap: 12rpx; flex-wrap: wrap; align-items: center; }
.seg-btn { font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 24rpx; background: #f1f3f5; color: #6b7280; }
.seg-btn.on { background: #1A56DB; color: #fff; }
.note { font-size: 24rpx; color: #8A9099; }
.sheet-btns { display: flex; gap: 24rpx; margin-top: 16rpx; }
.sheet-btns button { flex: 1; }
