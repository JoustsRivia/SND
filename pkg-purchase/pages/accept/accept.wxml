<!-- pkg-purchase/pages/accept/accept.wxml -->
<view class="page-pad">
  <view class="section-head">
    <view class="section-title">进场三步验收</view>
    <view class="section-sub">外观 → 性能 → 试验合格</view>
  </view>

  <view wx:if="{{idx < 0}}" class="empty">
    <view class="empty-icon">📦</view>
    <view class="empty-title">暂无待验收采购单</view>
    <view class="empty-desc">仅"已审批"的采购单可进场验收</view>
  </view>

  <block wx:if="{{idx >= 0}}">
    <view class="card">
      <view class="form-row">
        <text class="form-label">采购单</text>
        <picker range="{{purchases}}" range-key="name" value="{{idx}}" bindchange="onPick">
          <view class="form-value">{{purchases[idx].name}} ›</view>
        </picker>
      </view>
    </view>

    <view class="card step" wx:for="{{steps}}" wx:key="key">
      <view class="step-head">
        <text class="step-label">{{item.label}}</text>
        <view class="seg">
          <text class="seg-item {{item.pass ? 'on' : ''}}" data-i="{{index}}" bindtap="onPass">合格</text>
          <text class="seg-item {{item.pass ? '' : 'on danger'}}" data-i="{{index}}" bindtap="onPass">不合格</text>
        </view>
      </view>
      <view class="step-desc">{{item.desc}}</view>
      <input class="form-input left" placeholder="备注（选填）" value="{{item.remark}}" data-i="{{index}}" bindinput="bindRemark" />
    </view>

    <button class="btn btn-primary btn-block" loading="{{submitting}}" bindtap="onSubmit">提交验收</button>
  </block>
  <view class="safe-bottom"></view>
</view>
