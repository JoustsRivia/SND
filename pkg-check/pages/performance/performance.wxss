/* pkg-check/pages/performance/performance.wxss */
.perf { padding: 20rpx 24rpx 40rpx; }
.month-bar { font-size: 26rpx; color: #6b7280; padding: 4rpx 0 16rpx; }
.month-bar .m { color: #1A56DB; font-weight: 600; }
.tabs { display: flex; background: #fff; border-radius: 14rpx; overflow: hidden; margin-bottom: 20rpx; }
.tab { flex: 1; text-align: center; padding: 22rpx 0; font-size: 28rpx; color: #6b7280; }
.tab.on { color: #1A56DB; font-weight: 600; background: #eef3ff; }

.summary { display: flex; background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.s-item { flex: 1; text-align: center; display: flex; flex-direction: column; gap: 6rpx; }
.s-item .n { font-size: 36rpx; font-weight: 700; color: #1A56DB; }
.s-item .l { font-size: 24rpx; color: #8A9099; }

.empty { text-align: center; color: #9AA0A6; padding: 80rpx 0; }
.r-card { display: flex; align-items: center; gap: 20rpx; background: #fff; border-radius: 16rpx; padding: 22rpx 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.rk { width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center; border-radius: 50%; background: #f1f3f5; color: #6b7280; font-weight: 700; flex-shrink: 0; }
.rk.top { background: #1A56DB; color: #fff; }
.r-main { flex: 1; }
.r-hd { display: flex; justify-content: space-between; }
.name { font-size: 28rpx; font-weight: 500; }
.avg { font-size: 30rpx; font-weight: 700; color: #1A56DB; }
.bar { height: 14rpx; background: #eef1f5; border-radius: 8rpx; margin: 10rpx 0 6rpx; overflow: hidden; }
.bar-fill { height: 100%; background: linear-gradient(90deg,#5b9bff,#1A56DB); border-radius: 8rpx; }
.cnt { font-size: 22rpx; color: #8A9099; }

.form { background: #fff; border-radius: 16rpx; padding: 12rpx 24rpx; margin-bottom: 20rpx; }
.row { display: flex; align-items: center; gap: 16rpx; padding: 18rpx 0; border-bottom: 1rpx solid #f0f2f5; }
.k { width: 110rpx; color: #6b7280; font-size: 28rpx; flex-shrink: 0; }
.inp { flex: 1; font-size: 28rpx; }
.picker { font-size: 28rpx; color: #1f2329; }
.form button { margin-top: 20rpx; background: #1A56DB; color: #fff; }
.sub-hd { font-size: 26rpx; color: #6b7280; margin: 8rpx 4rpx 12rpx; }
.mini-row { display: flex; justify-content: space-between; align-items: center; background: #fff; border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 12rpx; font-size: 26rpx; }
.badge { font-weight: 600; color: #1A56DB; }
.badge.ok { color: #1A9E5B; }
.badge.bad { color: #E5484D; }
