<!-- pkg-check/pages/performance/performance.wxml -->
<view class="perf">
  <view class="month-bar">考核月份：<text class="m">{{month}}</text></view>
  <view class="tabs">
    <view class="tab {{tab==='rank'?'on':''}}" data-v="rank" bindtap="onTab">排行榜</view>
    <view class="tab {{tab==='score'?'on':''}}" data-v="score" bindtap="onTab">评分</view>
    <view class="tab {{tab==='reward'?'on':''}}" data-v="reward" bindtap="onTab">奖惩</view>
  </view>

  <!-- 排行榜 -->
  <block wx:if="{{tab==='rank'}}">
    <view wx:if="{{summary}}" class="summary">
      <view class="s-item"><text class="n">{{summary.personCount}}</text><text class="l">参评人数</text></view>
      <view class="s-item"><text class="n">{{summary.avg}}</text><text class="l">平均分</text></view>
      <view class="s-item"><text class="n">{{summary && summary.top ? summary.top.name : '-'}}</text><text class="l">第一名</text></view>
    </view>
    <view wx:if="{{rank.length===0}}" class="empty">本月暂无评分</view>
    <view wx:for="{{rank}}" wx:key="personId" class="r-card">
      <text class="rk {{item.rank<=3?'top':''}}">{{item.rank}}</text>
      <view class="r-main">
        <view class="r-hd"><text class="name">{{item.personName}}</text><text class="avg">{{item.avg}}</text></view>
        <view class="bar"><view class="bar-fill" style="width:{{item._w}}%"></view></view>
        <text class="cnt">{{item.cnt}} 次评分</text>
      </view>
    </view>
  </block>

  <!-- 评分 -->
  <block wx:if="{{tab==='score'}}">
    <view class="form">
      <view class="row"><text class="k">工号</text><input class="inp" placeholder="被考核人工号" value="{{personId}}" bindinput="bindPerson" /></view>
      <view class="row"><text class="k">姓名</text><input class="inp" placeholder="被考核人姓名" value="{{personName}}" bindinput="bindPersonName" /></view>
      <view class="row"><text class="k">维度</text>
        <picker mode="selector" range="{{dims}}" value="{{dimIdx}}" bindchange="onPickDim">
          <view class="picker">{{dims[dimIdx]}} ▾</view>
        </picker>
      </view>
      <view class="row"><text class="k">分值</text>
        <picker mode="selector" range="{{scoreLabels}}" value="2" bindchange="onPickScore">
          <view class="picker">{{score}} 分 ▾</view>
        </picker>
      </view>
      <button type="primary" loading="{{submitting}}" bindtap="onSubmitScore">提交评分</button>
    </view>
    <view class="sub-hd">本月评分记录</view>
    <view wx:for="{{scores}}" wx:key="_id" class="mini-row">
      <text>{{item.personName}} · {{item.dimension}}</text><text class="badge">{{item.score}}</text>
    </view>
  </block>

  <!-- 奖惩 -->
  <block wx:if="{{tab==='reward'}}">
    <view class="form">
      <view class="row"><text class="k">工号</text><input class="inp" placeholder="人员工号" value="{{rpersonId}}" bindinput="bindRPerson" /></view>
      <view class="row"><text class="k">姓名</text><input class="inp" placeholder="人员姓名" value="{{rpersonName}}" bindinput="bindRPersonName" /></view>
      <view class="row"><text class="k">类型</text>
        <picker mode="selector" range="{{rewardTypes}}" range-key="n" value="{{rtypeIdx}}" bindchange="onPickRtype">
          <view class="picker">{{rewardTypes[rtypeIdx].n}} ▾</view>
        </picker>
      </view>
      <view class="row"><text class="k">事由</text><input class="inp" placeholder="奖励/处罚事由" value="{{rreason}}" bindinput="bindRReason" /></view>
      <view class="row"><text class="k">金额</text><input class="inp" type="digit" placeholder="金额(选填)" value="{{ramount}}" bindinput="bindRAmount" /></view>
      <button type="primary" bindtap="onSubmitReward">登记奖惩</button>
    </view>
    <view class="sub-hd">本月奖惩记录</view>
    <view wx:for="{{rewards}}" wx:key="_id" class="mini-row">
      <text>{{item.personName}} · {{item._type}}{{item.reason ? ' · ' + item.reason : ''}}</text>
      <text class="badge {{item.type==='reward'?'ok':'bad'}}">{{item.amount ? '¥'+item.amount : ''}}</text>
    </view>
  </block>
</view>
